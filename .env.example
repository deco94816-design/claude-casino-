# Telegram Bot Token (get from @BotFather) — REQUIRED
BOT_TOKEN=your_bot_token_here

# Primary admin Telegram user ID (read by optimus/config.py)
ADMIN_ID=8311802199

# Optional: Telegram payments provider token (leave blank for Stars-only)
PROVIDER_TOKEN=

# Optional: bot username used for the in-profile bonus check
BOT_USERNAME=Librate

# OxaPay API key for crypto deposits (read by auto_deposit.py)
OXAPAY_KEY=your_oxapay_key_here
